# Dependencies (e.g. local tooling)
node_modules/
.bun/

# Rust/Cargo — compiled artifacts (matches `target/` at repo root, under `rust/`, or any nested workspace)
target/

# Build output
dist/
build/
*.compiled

# Environment
.env
.env.local
.env.*.local

# Local data (never commit email data)
.zmail/
/data/
maildir/
*.db
*.db-shm
*.db-wal
vectors/
*.eml
!tests/fixtures/**/*.eml

# Credentials and secrets
*.pem
*.key
google-credentials.json
oauth-tokens.json

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
*.swp
*.swo

# Claude Code — local settings (never commit)
.claude/

# Logs
*.log
logs/

# Agent scratch space — keep the directory, ignore contents
/tmp/*
!/tmp/.gitkeep
