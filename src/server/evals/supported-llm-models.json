{
  "version": 2,
  "description": "2026 eval lineup. Brain server default when unset: openai + gpt-5.4-mini (see docs/architecture/configuration.md). Each (provider, id) must exist in getModel() for @mariozechner/pi-ai. tested=true = regression baseline. costPerMillionTokens matches getModel().cost in pi-ai (USD per 1M input/output/cache tokens) for COGS estimates. See docs/architecture/pi-agent-stack.md#llm-model-ids-and-tool-compatibility.",
  "pricing": {
    "currency": "USD",
    "perMillionTokens": "input, output, cacheRead, cacheWrite — same fields as @mariozechner/pi-ai Model.cost; used to estimate eval spend when API-reported cost is missing.",
    "alignedWith": "@mariozechner/pi-ai",
    "piAiVersion": "0.66.1"
  },
  "providers": {
    "anthropic": {
      "default": "claude-sonnet-4-6",
      "candidates": [
        {
          "id": "claude-sonnet-4-6",
          "tested": true,
          "label": "2026 default — Sonnet 4.6 (1M context)",
          "costPerMillionTokens": { "input": 3, "output": 15, "cacheRead": 0.3, "cacheWrite": 3.75 }
        },
        {
          "id": "claude-haiku-4-5-20251001",
          "tested": true,
          "label": "Fast / cost-efficient (Haiku 4.5)",
          "costPerMillionTokens": { "input": 1, "output": 5, "cacheRead": 0.1, "cacheWrite": 1.25 }
        },
        {
          "id": "claude-opus-4-6",
          "tested": true,
          "label": "Highest capability in registry (Opus 4.6)",
          "costPerMillionTokens": { "input": 5, "output": 25, "cacheRead": 0.5, "cacheWrite": 6.25 }
        }
      ]
    },
    "openai": {
      "default": "gpt-5.4-mini",
