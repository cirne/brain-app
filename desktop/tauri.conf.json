{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Brain",
  "version": "0.1.0",
  "identifier": "com.cirne.brain",
  "build": {
    "frontendDist": "http://localhost:18473",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run desktop:bundle-server"
  },
  "app": {
    "windows": [
      {
        "title": "Brain",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:3000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "resources": ["resources/server-bundle"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
