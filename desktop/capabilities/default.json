{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "permissions": [
    "core:default",
    "process:default",
    "shell:default"
  ]
}
