# Wiki buildout + cleanup (lint) agent eval — same agents as Your Wiki (see wikiExpansionRunner).
# Requires BRAIN_HOME with ripmail index for buildout (search_index). Run: npm run eval:build
{"id":"wiki-001-buildout-smoke","agent":"buildout","userMessage":"Eval pass: call search_index once (pattern Enron, after 2000-12-31 before 2002-01-01). Then create topics/eval-wiki-smoke.md with exactly two markdown bullets citing one fact from the search results. Stop after that write.","expect":{"all":[{"kind":"toolNamesIncludeAll","names":["search_index","write"]}]}}
{"id":"wiki-002-cleanup-smoke","agent":"cleanup","userMessage":"Eval pass: use find to list .md files under the vault, read me.md if present. Grep one file for [[ wikilink patterns. Make at most one small edit if you find a clearly broken link; otherwise say no change. Keep this pass short.","expect":{"all":[{"kind":"toolNamesIncludeOneOf","names":["grep","find","read","edit"]}]}}
{"id":"wiki-003-gov-affairs-reorg-synthesis","agent":"buildout","userMessage":"Eval pass: research Richard Shapiro's November 2001 government affairs reorganization using search_index. Write or edit people/richard-shapiro.md to capture (1) who took over the U.S. Energy group and (2) which people continued handling California issues. The page must synthesize these facts — not just note that a reorg email exists. Stop after the write or edit.","expect":{"all":[{"kind":"toolNamesIncludeAll","names":["search_index","write"]},{"kind":"toolResultIncludes","substring":"Steffes","caseInsensitive":true},{"kind":"finalTextIncludes","substring":"Steffes","caseInsensitive":true}]}}
{"id":"wiki-004-person-page-depth","agent":"buildout","userMessage":"Eval pass: research Jeff Dasovich (jeff.dasovich@enron.com) using search_index and at least one read_email. Write people/jeff-dasovich.md. The page must go beyond a contact card: include what he works on, who he works with, and at least one assistant-facing note about his standing focus or how to work with him. Stop after the write.","expect":{"all":[{"kind":"toolNamesIncludeAll","names":["search_index","write"]},{"kind":"any","any":[{"kind":"finalTextIncludes","substring":"California","caseInsensitive":true},{"kind":"toolResultIncludes","substring":"California","caseInsensitive":true}]}]}}
{"id":"wiki-005-topic-synthesis-depth","agent":"buildout","userMessage":"Eval pass: research Enron's California direct access suspension from late 2001 using search_index and read_email. Write topics/direct-access.md. The page must include a 'Why it matters here' or equivalent section and at least three synthesized fact bullets about the suspension timeline or key positions — not just 'appears in mail about X'. Stop after the write.","expect":{"all":[{"kind":"toolNamesIncludeAll","names":["search_index","write"]},{"kind":"finalTextIncludes","substring":"direct access","caseInsensitive":true},{"kind":"any","any":[{"kind":"toolResultIncludes","substring":"suspension","caseInsensitive":true},{"kind":"finalTextIncludes","substring":"suspension","caseInsensitive":true}]}]}}
