# Single root for durable Brain data (default in dev: ./data). Tauri sets this when bundled.
# BRAIN_HOME=/Users/yourname/Library/Application Support/Brain
#
# Docker (`npm run docker:up`): runs `docker:ripmail:build` first (Linux ripmail → .docker/linux-ripmail/).
# compose sets BRAIN_HOME=/brain, PORT=4000 (in-container), and
# publishes host ${BRAIN_DOCKER_PORT:-4000}→4000. `PORT` in this file is ignored for listen port inside
# the container. Compose sets PUBLIC_WEB_ORIGIN=http://localhost:4000 — register that redirect URI in Google Console (not only 127.0.0.1).

ANTHROPIC_API_KEY=
RIPMAIL_BIN=ripmail
# `npm run dev` auto-sets RIPMAIL_BIN to the workspace binary when built: prefers
# target/debug/ripmail, else target/release/ripmail (after `npm run ripmail:build`).
# Override explicitly if needed:
# RIPMAIL_BIN=/absolute/path/to/target/debug/ripmail
# RIPMAIL_BIN=/absolute/path/to/target/release/ripmail
# Override for standalone ripmail / tests; Brain defaults to $BRAIN_HOME/ripmail when unset.
# RIPMAIL_HOME=/path/to/ripmail/home

RIPMAIL_EMAIL_ADDRESS=
RIPMAIL_IMAP_PASSWORD=
# Used by ripmail setup validation and optional ripmail LLM features (see docs/architecture/configuration.md)
OPENAI_API_KEY=
# Default 3000 — `npm run dev` and non-bundled `node dist/server` (Gmail OAuth redirect must match; see docs/google-oauth.md). Brain.app uses 18473 instead.
PORT=3000

# Optional: public URL you open in the browser (scheme + host + port, no trailing slash). When set,
# Gmail OAuth redirect uses this origin so sign-in returns to the same host as the SPA (fixes
# localhost vs 127.0.0.1 cookie split). Docker Compose sets http://localhost:4000 by default.
# PUBLIC_WEB_ORIGIN=http://localhost:4000

# Gmail OAuth (in-app flow; redirect URI is fixed in code — see docs/google-oauth.md)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: if set, overrides the mapping from GOOGLE_OAUTH_* for ripmail subprocess token refresh
# RIPMAIL_GOOGLE_OAUTH_CLIENT_ID=
# RIPMAIL_GOOGLE_OAUTH_CLIENT_SECRET=

# Tauri release: derive key for embedding allowlisted secrets from this file (or export BRAIN_EMBED_MASTER_KEY):
# LLM/tool *_API_KEY entries, EXA/SUPADATA, and GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET (Gmail in Brain.app).
# BRAIN_EMBED_MASTER_KEY=
