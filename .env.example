WIKI_DIR=/Users/yourname/brain
# Optional: full HTTPS URL with embedded PAT for private wiki or push (used only by container start.sh clone)
# WIKI_GIT_TOKEN=https://x-access-token:YOUR_GITHUB_PAT@github.com/you/brain.git
AUTH_USER=lew
AUTH_PASS=changeme
ANTHROPIC_API_KEY=
RIPMAIL_BIN=ripmail
# Docker/Fly: volume mounts ripmail index at /ripmail — RIPMAIL_HOME defaults to ~/.ripmail (wrong in containers)
# RIPMAIL_HOME=/ripmail
PORT=3000

# Optional: append-only agent wiki edit log (default ./data/wiki-edits.jsonl; on Fly same volume as ripmail: /ripmail/wiki-edits.jsonl)
# WIKI_EDIT_HISTORY_PATH=

# Calendar — ICS feed URLs (copy from Google Calendar settings > "Secret address in iCal format")
CIRNE_TRAVEL_ICS_URL=
LEW_PERSONAL_ICS_URL=

# Docker: wiki is cloned into /wiki inside the container (see WIKI_GIT_TOKEN). Only ripmail is bind-mounted.
