# Single root for durable Brain data (default in dev: ./data). Tauri sets this when bundled.
# BRAIN_HOME=/Users/yourname/Library/Application Support/Brain
#
# Multi-tenant / hosted cloud: mounted volume root; each tenant gets a UUID subdirectory as home.
# Do not set BRAIN_HOME when BRAIN_DATA_ROOT is set (server resolves per-request tenant home).
# BRAIN_DATA_ROOT=/mnt/brain-data
# Local multi-tenant dev: `npm run dev` sets BRAIN_DATA_ROOT=./data (gitignored).
#
# OPP-051 Phase 0 — Enron demo tenant (hosted / Docker only): Bearer mint for Playwright & demos without Google OAuth.
# Operator runbook: docs/architecture/enron-demo-tenant.md
# Requires BRAIN_DATA_ROOT. Set BRAIN_ENRON_DEMO_SECRET (any non-empty value) to enable `/api/auth/demo/enron` and `/demo`; no separate feature flag.
# BRAIN_ENRON_DEMO_SECRET=demo-secret
# Optional operator lock: mint only the registry tenant with this id (clear unset = all three demo users).
# BRAIN_ENRON_DEMO_TENANT_ID=usr_enrondemo00000000001
#
# Registry (keys kean | lay | skilling): eval/fixtures/enron-demo-registry.json
#
# OPP-051 — Enron demo mail must exist before Bearer mint / `/demo` (seed CLI writes tenants under BRAIN_DATA_ROOT). Mint returns **503** `demo_not_seeded` if `ripmail.db` is empty and no provision marker. Optional `EVAL_ENRON_TAR` uses an existing tarball; otherwise scripts prefer `./data/.cache/enron/enron_mail_20150507.tar.gz` then download if missing. Host CLI — matches local `npm run dev` tree when `./data`:
#   npm run brain:seed-enron-demo          # all three mailboxes
#   BRAIN_ENRON_DEMO_USER=lay node scripts/brain/seed-enron-demo-tenant.mjs   # one mailbox
#   BRAIN_DATA_ROOT=./data node scripts/brain/seed-enron-demo-tenant.mjs --all
#
# Docker: `npm run docker:up` runs `docker compose up --build` (see docker-compose.yml).
# Optional on Apple Silicon: `BRAIN_DOCKER_PLATFORM=linux/amd64` when you need an amd64 engine image.
# BRAIN_DOCKER_PLATFORM=linux/amd64
#
# compose sets BRAIN_DATA_ROOT=/brain-data, PORT=4000 (in-container), and
# publishes host ${BRAIN_DOCKER_PORT:-4000}→4000. `PORT` in this file is ignored for listen port inside
# the container. Compose sets PUBLIC_WEB_ORIGIN=http://localhost:4000 — register that redirect URI in Google Console (not only 127.0.0.1).
#
# Client: emit source maps for prod-like debugging (`npm run build:client:map` sets this for one build; optional in .env for tooling).
# BRAIN_CLIENT_SOURCEMAP=1
#
# Hosted / Docker: server runs periodic `ripmail refresh` for every `usr_*` under BRAIN_DATA_ROOT on a timer.
# Cadence from SYNC_INTERVAL_SECONDS (unset → 300 seconds; see `getSyncIntervalMs` in `src/server/lib/platform/syncAll.ts`).
# SYNC_INTERVAL_SECONDS=300

# Brain-to-brain collaboration is off unless set to 1 or true (Hub / Settings Brain access, GET/POST/PATCH/DELETE `/api/brain-query/grants`, mail-marker collaborator flows).
# BRAIN_B2B_ENABLED=1

ANTHROPIC_API_KEY=

# Server mail runs in-process (`src/server/ripmail/`). For manual CLI work, install
# the `ripmail` binary on PATH and run `npm run ripmail -- <subcommand>`.
# Ripmail refresh timeouts: see `RIPMAIL_REFRESH_TIMEOUT_MS` in `src/server/lib/ripmail/ripmailTimeouts.ts`.
# Expose GET /api/debug/children in production (metrics only): BRAIN_DEBUG_CHILDREN=1

# OPP-095 — Skip wiki first-draft bootstrap (run continuous Your Wiki supervisor immediately). Operators / dev only.
# WIKI_BOOTSTRAP_SKIP=true

RIPMAIL_EMAIL_ADDRESS=
RIPMAIL_IMAP_PASSWORD=
# Used by ripmail setup validation and optional ripmail LLM features (see docs/architecture/configuration.md)
# Also powers “Read answers aloud” (OpenAI TTS on `speak`, no browser voice).
OPENAI_API_KEY=
# Org admin key: `npm run llm:usage` (Usage + Costs APIs, not chat). Create in OpenAI org settings.
OPENAI_ADMIN_API_KEY=
# Optional: OpenAI project id for `npm run llm:usage` filters (defaults to the built-in Braintunnel project).
# BRAIN_OPENAI_PROJECT_ID=proj_...
# Optional TTS overrides for `speak` (defaults: tts-1 / alloy / mp3).
# BRAIN_TTS_MODEL=tts-1
# BRAIN_TTS_VOICE=alloy
# BRAIN_TTS_RESPONSE_FORMAT=mp3
# Optional STT model for POST /api/transcribe (hold-to-speak on mobile; default whisper-1).
# BRAIN_STT_MODEL=whisper-1
# Optional ISO-639-1 language code (e.g. en) — improves short/noisy holds; unset = auto-detect.
# BRAIN_STT_LANGUAGE=en
# xAI (Grok): set BRAIN_LLM=xai/grok-4-1-fast (or shorthand `grok`) — see src/server/evals/supported-llm-models.json
XAI_API_KEY=

# Brain agent — standard tier (default when unset: openai/gpt-5.4-mini). Grammar: provider/model, bare id from
# supported-llm-models.json, or nicknames (sonnet, haiku, gpt-5.4, …). Must match *_API_KEY for the provider.
# BRAIN_LLM=openai/gpt-5.4-mini
# BRAIN_LLM=anthropic/sonnet
# BRAIN_LLM=xai/grok-4-1-fast
# Optional fast/cheap tier: B2B tunnel preflight, suggest-reply repair, hub Drive suggestions (falls back to BRAIN_LLM when unset).
# BRAIN_FAST_LLM=haiku
# BRAIN_FAST_LLM=openai/gpt-5.4-nano
# Local MLX (Apple Silicon): `mlx_lm.server --model mlx-community/Qwen3.6-27B-4bit --port 11444`
# BRAIN_LLM=mlx-local/mlx-community/Qwen3.6-27B-4bit
# MLX_LOCAL_BASE_URL=http://localhost:11444/v1
# MLX_LOCAL_API_KEY=local
# MLX local Qwen: extended thinking off by default (faster). Set to 1 to enable thinking.
# MLX_LOCAL_THINKING=1
# Legacy LLM_PROVIDER / LLM_MODEL are ignored — migrate to BRAIN_LLM (startup logs a one-time warning if still set).
# Set to 0 to disable the server follow-up that adds `suggest_reply` chips when the main turn omitted them. Default: on (unset or any value except 0).
# Optional suggest-reply repair overrides (default: BRAIN_FAST_LLM / BRAIN_LLM tier). Provider + model must both be set if overriding.
# BRAIN_SUGGEST_REPLY_REPAIR=0
# BRAIN_SUGGEST_REPLY_REPAIR_PROVIDER=
# BRAIN_SUGGEST_REPLY_REPAIR_MODEL=
# Default 3000 — `npm run dev` and non-bundled `node dist/server` (Gmail OAuth redirect must match; see docs/google-oauth.md). Braintunnel.app uses 18473 instead.
PORT=3000

# Optional: public URL you open in the browser (scheme + host + port, no trailing slash). When set,
# Gmail OAuth redirect uses this origin so sign-in returns to the same host as the SPA (fixes
# localhost vs 127.0.0.1 cookie split). Docker Compose sets http://localhost:4000 by default.
# DigitalOcean App Platform: set to your real https://… app URL (register the same redirect URI in Google Console).
# If unset in NODE_ENV=production, the server infers origin from X-Forwarded-Proto / Host — explicit is safer.
# PUBLIC_WEB_ORIGIN=http://localhost:4000

# Named tunnel public hostname for GUID gate middleware (remote access). Defaults match tunnelManager when unset.
# BRAIN_TUNNEL_GATE_HOST=...

# Gmail OAuth (in-app flow; redirect URI is fixed in code — see docs/google-oauth.md)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: if set, overrides the mapping from GOOGLE_OAUTH_* for ripmail subprocess token refresh
# RIPMAIL_GOOGLE_OAUTH_CLIENT_ID=
# RIPMAIL_GOOGLE_OAUTH_CLIENT_SECRET=

# Tauri release: derive key for embedding allowlisted secrets from this file (or export BRAIN_EMBED_MASTER_KEY):
# LLM/tool *_API_KEY entries, EXA/SUPADATA, and GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET (Gmail in Braintunnel.app).
# BRAIN_EMBED_MASTER_KEY=
# When set, also authorizes "Authorization: Bearer <same>" for OPP-048 GET /api/issues and GET /api/issues/:id (single-tenant, loopback/trusted use only).

# Optional: DigitalOcean API token for local `doctl` only (Brain server does not read this). Team is implied by
# whichever team was active when the token was created. See docs/digitalocean.md.
# DO_TOKEN=

# Optional: DigitalOcean container deploy (`npm run docker:deploy`). Registry path is fixed in scripts/docker-deploy-do.sh.
# Requires branch main, clean git tree; login first: ./scripts/doctl-brain.sh registry login
# Default image/git tag is UTC deploy-YYYYMMDD-HHMMSSutc unless overridden:
# DOCKER_IMAGE_TAG=my-override-tag
# DOCKER_PUBLISH_LATEST=0
# DOCKER_PUBLISH_PLATFORM=linux/arm64   # default is linux/amd64 (typical DO droplets)
# NEW_RELIC_API_KEY=NRAK-...              # user API key for `newrelic` CLI deployment marker (not the Node license key)
# SKIP_NEW_RELIC_DEPLOYMENT=1             # skip New Relic marker if CLI/key unavailable
# Optional: after tagging, `scripts/generate-release-notes.ts` uses OPENAI_API_KEY (also listed above) to write
# `docs/release-notes/<deploy-tag>.md` and to populate `--description` / `--changelog` on the NR deployment.
# RELEASE_NOTES_MODEL=gpt-4.1-mini
# SKIP_RELEASE_NOTES=1                    # skip LLM step; NR uses generic description/changelog
