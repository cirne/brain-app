# Single root for durable Brain data (default in dev: ./data). Tauri sets this when bundled.
# BRAIN_HOME=/Users/yourname/Library/Application Support/Brain
#
# Multi-tenant / hosted cloud: mounted volume root; each tenant gets a UUID subdirectory as home.
# Do not set BRAIN_HOME when BRAIN_DATA_ROOT is set (server resolves per-request tenant home).
# BRAIN_DATA_ROOT=/mnt/brain-data
# Local multi-tenant dev: `npm run dev:multitenant` sets BRAIN_DATA_ROOT=./data-multitenant (gitignored).
#
# Docker (`npm run docker:up`): runs `docker:ripmail:build` first (Linux ripmail → .docker/linux-ripmail/).
# compose sets BRAIN_DATA_ROOT=/brain-data, PORT=4000 (in-container), and
# publishes host ${BRAIN_DOCKER_PORT:-4000}→4000. `PORT` in this file is ignored for listen port inside
# the container. Compose sets PUBLIC_WEB_ORIGIN=http://localhost:4000 — register that redirect URI in Google Console (not only 127.0.0.1).

ANTHROPIC_API_KEY=
RIPMAIL_BIN=ripmail
# `npm run dev` auto-sets RIPMAIL_BIN to the workspace binary when built: prefers
# target/debug/ripmail, else target/release/ripmail (after `npm run ripmail:build`).
# Override explicitly if needed:
# RIPMAIL_BIN=/absolute/path/to/target/debug/ripmail
# RIPMAIL_BIN=/absolute/path/to/target/release/ripmail
# Override for standalone ripmail / tests; Brain defaults to $BRAIN_HOME/ripmail when unset.
# RIPMAIL_HOME=/path/to/ripmail/home

# Ripmail child timeouts are constants in `src/server/lib/ripmailRun.ts` (not env).
# Expose GET /api/debug/children in production (metrics only): BRAIN_DEBUG_CHILDREN=1

RIPMAIL_EMAIL_ADDRESS=
RIPMAIL_IMAP_PASSWORD=
# Used by ripmail setup validation and optional ripmail LLM features (see docs/architecture/configuration.md)
OPENAI_API_KEY=
# xAI (Grok): set LLM_PROVIDER=xai and LLM_MODEL (e.g. grok-4-1-fast) — see src/server/evals/supported-llm-models.json
XAI_API_KEY=

# Brain agent (defaults when unset: openai + gpt-5.4-mini). Must match *_API_KEY for LLM_PROVIDER.
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-5.4-mini
# LLM_PROVIDER=xai
# LLM_MODEL=grok-4-1-fast
# Default 3000 — `npm run dev` and non-bundled `node dist/server` (Gmail OAuth redirect must match; see docs/google-oauth.md). Braintunnel.app uses 18473 instead.
PORT=3000

# Optional: public URL you open in the browser (scheme + host + port, no trailing slash). When set,
# Gmail OAuth redirect uses this origin so sign-in returns to the same host as the SPA (fixes
# localhost vs 127.0.0.1 cookie split). Docker Compose sets http://localhost:4000 by default.
# DigitalOcean App Platform: set to your real https://… app URL (register the same redirect URI in Google Console).
# If unset in NODE_ENV=production, the server infers origin from X-Forwarded-Proto / Host — explicit is safer.
# PUBLIC_WEB_ORIGIN=http://localhost:4000

# Gmail OAuth (in-app flow; redirect URI is fixed in code — see docs/google-oauth.md)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Optional: if set, overrides the mapping from GOOGLE_OAUTH_* for ripmail subprocess token refresh
# RIPMAIL_GOOGLE_OAUTH_CLIENT_ID=
# RIPMAIL_GOOGLE_OAUTH_CLIENT_SECRET=

# Tauri release: derive key for embedding allowlisted secrets from this file (or export BRAIN_EMBED_MASTER_KEY):
# LLM/tool *_API_KEY entries, EXA/SUPADATA, and GOOGLE_OAUTH_CLIENT_ID / GOOGLE_OAUTH_CLIENT_SECRET (Gmail in Braintunnel.app).
# BRAIN_EMBED_MASTER_KEY=

# Optional: DigitalOcean API token for local `doctl` only (Brain server does not read this). Team is implied by
# whichever team was active when the token was created. See docs/digitalocean.md.
# DO_TOKEN=

# Optional: overrides for `npm run docker:publish` (registry path is hardcoded in scripts/docker-publish-do.sh).
# Login first: ./scripts/doctl-brain.sh registry login
# DOCKER_IMAGE_TAG=0.1.0
# DOCKER_PUBLISH_LATEST=0
# DOCKER_PUBLISH_PLATFORM=linux/arm64   # default is linux/amd64 (typical DO droplets)
