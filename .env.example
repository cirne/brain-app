WIKI_DIR=/Users/yourname/brain
# Optional: full HTTPS URL with embedded PAT for private wiki or push (used only by container start.sh clone)
# WIKI_GIT_TOKEN=https://x-access-token:YOUR_GITHUB_PAT@github.com/you/brain.git
AUTH_USER=lew
AUTH_PASS=changeme
ANTHROPIC_API_KEY=
RIPMAIL_BIN=ripmail
# Container: ripmail data lives under /ripmail (Dockerfile ENV). Local dev: defaults to ~/.ripmail if unset
# RIPMAIL_HOME=/ripmail

# Non-interactive ripmail setup (container start.sh when config.json is missing). Gmail: use an app password.
RIPMAIL_EMAIL_ADDRESS=
RIPMAIL_IMAP_PASSWORD=
# Used by ripmail setup validation and the agent (see OPENAI in AGENTS.md)
OPENAI_API_KEY=
PORT=3000

# Optional: append-only agent wiki edit log (default ./data/wiki-edits.jsonl under cwd)
# WIKI_EDIT_HISTORY_PATH=

# Calendar — ICS feed URLs (copy from Google Calendar settings > "Secret address in iCal format")
CIRNE_TRAVEL_ICS_URL=
LEW_PERSONAL_ICS_URL=

# Docker: wiki is cloned into /wiki inside the container. Ripmail uses /ripmail inside the image (no volume).
