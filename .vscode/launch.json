{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/tsx",
      "runtimeArgs": [
        "watch",
        "--exclude",
        ".env",
        "--exclude",
        ".env.local",
        "--exclude",
        ".env.development",
        "--exclude",
        ".env.production",
        "--exclude",
        ".env.test"
      ],
      "args": ["src/server/index.ts"],
      "envFile": "${workspaceFolder}/.env",
      "cwd": "${workspaceFolder}",
      "sourceMaps": true,
      "console": "integratedTerminal",
      "restart": true
    }
  ]
}
