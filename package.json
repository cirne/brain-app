{
  "name": "brain-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:kill": "for p in $(lsof -ti :3000 2>/dev/null); do kill -9 \"$p\"; done",
    "oauth:print-redirect-uri": "node scripts/print-google-oauth-redirect-uri.mjs",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server-bundle.mjs && node scripts/copy-user-skills.mjs",
    "start": "node dist/server/index.js",
    "sync": "node dist/server/sync-cli.js",
    "start:local": "NODE_ENV=production AUTH_DISABLED=true PORT=4000 node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && cargo fmt --all -- --check && cargo clippy --workspace -- -D warnings && cargo test --workspace",
    "ripmail:build": "cargo build -p ripmail --release",
    "ripmail:dev": "cargo build -p ripmail",
    "ripmail:test": "cargo test -p ripmail",
    "brain:clean:dev": "node scripts/clean-brain-dev-data.mjs",
    "desktop": "tauri",
    "desktop:bundle-server": "node scripts/bundle-tauri-server.mjs",
    "desktop:clean-data": "node scripts/clean-tauri-user-data.mjs",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:fresh": "node scripts/desktop-fresh.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@mariozechner/pi-web-ui": "^0.66.1",
    "better-sqlite3": "^11.0.0",
    "diff": "^9.0.0",
    "exa-js": "^2.11.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.0",
    "marked": "^15.0.0",
    "papaparse": "^5.5.3",
    "rrule": "^2.8.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "lucide-svelte": "^1.0.1",
    "svelte": "^5.0.0",
    "svelte-eslint-parser": "^0.43.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
