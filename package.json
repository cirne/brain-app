{
  "name": "brain-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:eval": "node scripts/run-dev-eval.mjs",
    "dev:eval:clean": "node scripts/clean-eval-brain.mjs",
    "dev:multitenant": "node scripts/run-dev-multitenant.mjs",
    "dev:desktop-home": "node scripts/run-dev-desktop-home.mjs",
    "dev:kill": "for p in $(lsof -ti :3000 2>/dev/null); do kill -9 \"$p\"; done",
    "oauth:print-redirect-uri": "node scripts/print-google-oauth-redirect-uri.mjs",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "node scripts/build-server-bundle.mjs && node scripts/copy-user-skills.mjs",
    "start": "node dist/server/index.js",
    "sync": "node dist/server/sync-cli.js",
    "start:local": "NODE_ENV=production PORT=4000 node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "ci": "npm run lint && npm run typecheck && npm run test && cargo fmt --all -- --check && cargo clippy -p brain -- -D warnings && cargo test -p brain --lib",
    "ripmail:build": "cargo build -p ripmail --release",
    "ripmail:dev": "cargo build -p ripmail",
    "ripmail:test": "cargo t -p ripmail",
    "dev:clean": "node scripts/clean-brain-dev-data.mjs",
    "usage:export": "node scripts/brain-usage.mjs",
    "desktop": "tauri",
    "desktop:bundle-server": "node scripts/bundle-tauri-server.mjs",
    "desktop:clean-data": "node scripts/clean-tauri-user-data.mjs",
    "desktop:dev": "tauri dev",
    "desktop:build": "tauri build",
    "desktop:fresh": "node scripts/desktop-fresh.mjs",
    "desktop:setup-sidecars": "node scripts/setup-sidecars.mjs",
    "docker:ripmail:build": "node scripts/docker-prebuild-ripmail.mjs",
    "docker:build": "npm run docker:ripmail:build && docker build -t brain-app:local .",
    "docker:up": "npm run docker:ripmail:build && docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f brain",
    "docker:publish": "bash scripts/docker-publish-do.sh",
    "docker:build:arm64": "DOCKER_PLATFORM=linux/arm64 npm run docker:ripmail:build && docker buildx build --platform linux/arm64 -f Dockerfile -t brain-app:arm64-local --load .",
    "eval:build": "node scripts/eval/build-enron-kean.mjs",
    "eval:run": "BRAIN_HOME=./data-eval/brain vitest run --config vitest.eval.config.ts",
    "eval:run:assistant": "BRAIN_HOME=./data-eval/brain vitest run --config vitest.eval.config.ts src/server/evals/assistant",
    "eval:run:enron": "BRAIN_HOME=./data-eval/brain npx tsx --tsconfig tsconfig.server.json src/server/evals/enronV1cli.ts",
    "eval:run:wiki": "BRAIN_HOME=./data-eval/brain npx tsx --tsconfig tsconfig.server.json src/server/evals/wikiV1cli.ts",
    "issues:list": "node scripts/issues-http.mjs list",
    "issues:fetch": "node scripts/issues-http.mjs fetch"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@mariozechner/pi-agent-core": "^0.66.1",
    "@mariozechner/pi-ai": "^0.66.1",
    "@mariozechner/pi-coding-agent": "^0.66.1",
    "@mariozechner/pi-web-ui": "^0.66.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "better-sqlite3": "^11.0.0",
    "cloudflared": "^0.7.1",
    "diff": "^9.0.0",
    "exa-js": "^2.11.0",
    "gray-matter": "^4.0.3",
    "hono": "^4.12.14",
    "marked": "^15.0.0",
    "newrelic": "^13.19.2",
    "openai": "^4.104.0",
    "p-limit": "^4.0.0",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "selfsigned": "^2.4.1",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@sveltejs/vite-plugin-svelte": "^5.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-link": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.0.0",
    "eslint-plugin-svelte": "^2.0.0",
    "lucide-svelte": "^1.0.1",
    "svelte": "^5.0.0",
    "svelte-eslint-parser": "^0.43.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.0"
  }
}
