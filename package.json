{
  "name": "brain-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:clean": "node scripts/clean-dev-data-root.mjs",
    "dev:server": "node scripts/run-dev.mjs",
    "dev:eval": "node scripts/run-dev-eval.mjs",
    "dev:eval:clean": "node scripts/clean-eval-brain.mjs",
    "dev:kill": "for p in $(lsof -ti :3000 2>/dev/null); do kill -9 \"$p\"; done",
    "oauth:print-redirect-uri": "node scripts/print-google-oauth-redirect-uri.mjs",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:client:map": "BRAIN_CLIENT_SOURCEMAP=1 npm run build:client",
    "build:server": "node scripts/build-server-bundle.mjs && node scripts/copy-user-skills.mjs && node scripts/copy-starter-wiki.mjs",
    "start": "node dist/server/index.js",
    "sync": "node dist/server/sync-cli.js",
    "start:local": "node scripts/start-local.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "check:npm-malware": "tsx scripts/check-npm-lock-malware.ts",
    "design:lint": "npx -y @google/design.md lint DESIGN.md",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "ci": "npm run lint && npm run check:npm-malware && npm run typecheck && npm run test:coverage",
    "ci:brain": "cargo fmt -p brain -- --check && cargo clippy -p brain -- -D warnings && cargo test -p brain --lib",
    "usage:export": "node scripts/brain-usage.mjs",
    "llm:usage": "npx tsx scripts/llm-usage.ts",
    "docker:build": "docker build -t brain-app:local .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f brain",
    "docker:deploy": "bash scripts/docker-deploy-do.sh",
    "docker:build:arm64": "docker buildx build --platform linux/arm64 -f Dockerfile -t brain-app:arm64-local --load .",
    "brain:seed-enron-demo": "BRAIN_DATA_ROOT=./data node scripts/brain/seed-enron-demo-tenant.mjs --all",
    "eval:run": "BRAIN_DATA_ROOT=./data node scripts/eval-run.mjs",
    "test:e2e:enron": "vitest run -c vitest.enron-e2e.config.ts",
    "test:e2e:playwright": "playwright test",
    "issues:list": "node scripts/issues-http.mjs list",
    "issues:fetch": "node scripts/issues-http.mjs fetch",
    "ripmail": "ripmail"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.1",
    "@mariozechner/pi-agent-core": "^0.70.6",
    "@mariozechner/pi-ai": "^0.70.6",
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@mariozechner/pi-web-ui": "^0.70.6",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "better-sqlite3": "^12.9.0",
    "cloudflared": "^0.7.1",
    "diff": "^9.0.0",
    "exa-js": "^2.12.1",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "handlebars": "^4.7.9",
    "hono": "^4.12.18",
    "i18next": "^26.0.10",
    "i18next-browser-languagedetector": "^8.2.1",
    "imapflow": "^1.3.3",
    "mailparser": "^3.9.8",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "newrelic": "^13.19.2",
    "nodemailer": "^8.0.7",
    "openai": "^6.35.0",
    "p-limit": "^7.3.0",
    "papaparse": "^5.5.3",
    "pdf-parse": "^2.4.5",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "selfsigned": "^5.5.0",
    "tailwind-merge": "^3.5.0",
    "turndown": "^7.2.4",
    "xlsx": "^0.20.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@tiptap/core": "^3.22.5",
    "@tiptap/extension-bubble-menu": "^3.22.5",
    "@tiptap/extension-floating-menu": "^3.22.5",
    "@tiptap/extension-link": "^3.22.5",
    "@tiptap/extension-placeholder": "^3.22.5",
    "@tiptap/starter-kit": "^3.22.5",
    "@types/better-sqlite3": "^7.6.0",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/turndown": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "^4.1.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-plugin-svelte": "^3.17.1",
    "jsdom": "^29.1.1",
    "lucide-svelte": "^1.0.1",
    "pino-pretty": "^13.1.3",
    "svelte": "^5.55.5",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "@anthropic-ai/sdk": "0.91.1",
    "basic-ftp": "5.3.1",
    "fast-xml-builder": "1.2.0",
    "ip-address": "10.1.1",
    "uuid": "14.0.0"
  }
}
